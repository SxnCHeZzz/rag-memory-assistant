# Ollama — локальный LLM-сервер
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_TIMEOUT=120.0
OLLAMA_NUM_CTX=4096

# Qdrant — коллекция для документов
QDRANT_COLLECTION=documents

# Эмбеддинги
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_BATCH_SIZE=8

# Чанкинг
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# Поиск
RETRIEVAL_SCORE_THRESHOLD=0.60
HYBRID_SEARCH_ENABLED=true
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# Реранкер (опционально, по умолчанию выключен)
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_K_BEFORE=10
RERANKER_TOP_K_AFTER=5
RERANKER_BATCH_SIZE=4

# Диалог
CONVERSATION_HISTORY_MAX=10
CONVERSATION_SUMMARY_THRESHOLD=6

# Память — коллекция для фактов пользователя
MEMORY_COLLECTION=user_memory